{
  "name": "flux-lang-textmate",
  "displayName": "Flux-Lang (TextMate)",
  "description": "TextMate grammar for Flux-Lang (.flux). Imports into IntelliJ (Settings ▸ Editor ▸ TextMate Bundles) and works as a VS Code extension.",
  "version": "0.1.0",
  "publisher": "codewandler",
  "engines": { "vscode": "^1.0.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "flux",
        "aliases": ["Flux-Lang", "flux"],
        "extensions": [".flux"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flux",
        "scopeName": "source.flux",
        "path": "./syntaxes/flux.tmLanguage.json"
      }
    ]
  }
}
