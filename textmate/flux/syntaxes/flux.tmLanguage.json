{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flux-Lang",
  "scopeName": "source.flux",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#symbols" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtin-types" },
    { "include": "#types" }
  ],
  "repository": {
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.flux"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.flux",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [{ "include": "#interpolation" }]
        },
        {
          "name": "string.quoted.double.flux",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.flux", "match": "\\\\." },
            { "include": "#interpolation" }
          ]
        }
      ]
    },
    "interpolation": {
      "name": "meta.interpolation.flux",
      "match": "\\{[A-Za-z_][A-Za-z0-9_.]*\\}",
      "captures": { "0": { "name": "variable.other.interpolated.flux" } }
    },
    "annotations": {
      "match": "@[A-Za-z_][A-Za-z0-9_]*",
      "name": "keyword.other.annotation.flux"
    },
    "symbols": {
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*",
      "name": "variable.other.flux"
    },
    "constants": {
      "match": "\\b(true|false|null)\\b",
      "name": "constant.language.flux"
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.flux"
    },
    "keywords": {
      "match": "\\b(flow|type|goal|when|unless|else|repeat|until|each|in|flat|loop|watch|timeout|budget|for|every|match|case|default|route|fallback|branch|block|seq|pipe|parallel|race|try|catch|retry|confirm|throttle|debounce|assert|verify|memo|await|as|peek|return|do)\\b",
      "name": "keyword.control.flux"
    },
    "builtin-types": {
      "match": "\\b(String|Number|Bool|Any|List)\\b",
      "name": "support.type.flux"
    },
    "types": {
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b",
      "name": "entity.name.type.flux"
    }
  }
}
